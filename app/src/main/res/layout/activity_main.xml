<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/txtview_result"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="306dp"
        android:text="Result"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/edittxt_value"
        app:layout_constraintTop_toBottomOf="@+id/edittxt_value" />

    <TextView
        android:id="@+id/txtview_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="115dp"
        android:layout_marginBottom="72dp"
        android:text="Converter Calculator"
        app:layout_constraintBottom_toTopOf="@+id/spinner_source"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Spinner
        android:id="@+id/spinner_source"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="45dp"
        android:spinnerMode="dropdown"
        app:layout_constraintBottom_toTopOf="@+id/edittxt_value"
        app:layout_constraintEnd_toStartOf="@+id/txtview_arrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtview_title" />

    <Spinner
        android:id="@+id/spinner_destination"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginTop="207dp"
        android:layout_marginBottom="45dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_convert"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/txtview_arrow"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btn_convert"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="17dp"
        android:layout_marginBottom="383dp"
        android:text="Convert"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/edittxt_value"
        app:layout_constraintTop_toBottomOf="@+id/spinner_destination" />

    <EditText
        android:id="@+id/edittxt_value"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginEnd="17dp"
        android:layout_marginBottom="59dp"
        android:ems="10"
        android:hint="30"
        android:inputType="number"
        app:layout_constraintBottom_toTopOf="@+id/txtview_result"
        app:layout_constraintEnd_toStartOf="@+id/btn_convert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/spinner_source" />

    <TextView
        android:id="@+id/txtview_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="18dp"
        android:text="=>"
        app:layout_constraintBaseline_toBaselineOf="@+id/spinner_source"
        app:layout_constraintEnd_toStartOf="@+id/spinner_destination"
        app:layout_constraintStart_toEndOf="@+id/spinner_source" />

</androidx.constraintlayout.widget.ConstraintLayout>